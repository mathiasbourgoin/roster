{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "roster/benchmarks/quality-cost/cost-log",
  "title": "Per-stage cost log (one record per arm x problem x stage x seed)",
  "description": "Emitted by an arm adapter (Phase B). The deterministic scorer reads these; it never trusts agent self-report of cost.",
  "type": "object",
  "required": ["arm", "problem", "stage", "seed", "model", "model_version", "temperature", "input_tokens", "output_tokens", "total_tokens", "usd", "turns", "wall_clock_s", "date"],
  "additionalProperties": false,
  "properties": {
    "arm": { "type": "string", "description": "bare | roster@<ver> | speckit | ..." },
    "problem": { "type": "string" },
    "stage": { "type": "string", "enum": ["S1", "S2", "S3", "S4"] },
    "seed": { "type": "integer", "minimum": 0 },
    "model": { "type": "string" },
    "model_version": { "type": "string" },
    "temperature": { "type": "number" },
    "model_cutoff": { "type": "string", "description": "ISO date; for contamination audit" },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "total_tokens": { "type": "integer", "minimum": 0 },
    "usd": { "type": "number", "minimum": 0 },
    "turns": { "type": "integer", "minimum": 0, "description": "agent turns / tool-call rounds" },
    "wall_clock_s": { "type": "number", "minimum": 0, "description": "ADVISORY only — machine/load-dependent, not comparable across runs on a busy host (review M4). Tokens/usd are the comparable cross-arm cost; the runner must assert identical model+model_version+temperature across arms before comparing." },
    "date": { "type": "string", "description": "ISO date of the run" }
  }
}
