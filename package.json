{
  "name": "agent-roster",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "build:index": "node scripts/run-build-index.js",
    "build:ts": "tsc -p tsconfig.json",
    "check:agents": "npm run build:ts && node dist/scripts/check-agents.js",
    "check:skills": "node dist/scripts/check-skill-structure.js",
    "test": "npm run build:ts && node --test dist/scripts/build-index.test.js && node dist/scripts/check-agents.js && node dist/scripts/check-skill-structure.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
