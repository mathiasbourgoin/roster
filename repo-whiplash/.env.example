# Copy to .env and fill in. Never commit .env.

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-me"
# Base URL of the app (used for OAuth callbacks)
AUTH_URL="http://localhost:3000"

# --- GitHub OAuth App ---
# Create at https://github.com/settings/developers (OAuth App, NOT a GitHub App)
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
# Request the "repo" scope so private repos are visible.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- GitLab OAuth Application ---
# Create at https://gitlab.com/-/profile/applications
# Redirect URI: http://localhost:3000/api/auth/callback/gitlab
# Scopes: read_api read_user read_repository
AUTH_GITLAB_ID=""
AUTH_GITLAB_SECRET=""
# For self-managed GitLab, set the instance base URL (defaults to https://gitlab.com)
GITLAB_BASE_URL="https://gitlab.com"

# --- Database ---
DATABASE_URL="file:./dev.db"
